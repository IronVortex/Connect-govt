{
  "outputDirectory": "dist/apps/web/.next",
  "buildCommand": "pnpm nx build web",
  "installCommand": "pnpm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://connect-govt-api-ubki.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${NEXT_PUBLIC_API_URL}/api/:path*"
    }
  ]
}
