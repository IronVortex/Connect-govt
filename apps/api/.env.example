# API Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
# For Local MongoDB: mongodb://localhost:27017/dbname
MONGODB_URI=
MONGODB_DB=connect-govt

# Authentication & Security
JWT_SECRET=
JWT_EXPIRATION=1d
REFRESH_TOKEN_EXPIRATION=7d

# CORS Configuration
# Comma-separated list of allowed origins (e.g., https://app.com,https://staging.app.com)
FRONTEND_URL=

# Optional: Environment-specific settings
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Optional: Vision AI Classification (OpenAI)
# When set, document classification uses GPT-4o vision before OCR.
# Without it, a local visual-layout classifier is used.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
